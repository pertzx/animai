# AnimAI server — copie para .env e preencha
PORT=4000
MONGODB_URI=mongodb://localhost:27017/animai
JWT_SECRET=troque-por-um-segredo-forte
CLIENT_URL=http://localhost:5173

# E-mails que viram admin automaticamente ao se registrar (separados por vírgula)
ADMIN_EMAILS=voce@exemplo.com

# Limites de requisições de IA por mês
FREE_AI_REQUESTS_LIMIT=50
PRO_AI_REQUESTS_LIMIT=2000

# Providers de IA (fallback quando nenhum foi cadastrado no painel admin)
NVIDIA_API_KEY=
OPENAI_API_KEY=

# Stripe (opcional em dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PROP=

# ── Rotas locais (unificadas, sem serviços externos OpenReel) ─
# Todas estas URLs eram serviços externos OpenReel Cloud e agora
# são servidas localmente pelo próprio apps/server:
#   POST /api/share          — upload de share (antes: openreel-cloud.niiyeboah1996.workers.dev)
#   GET  /api/share/:id      — info do share
#   GET  /api/share/:id/download — redirect para URL de download
#   GET  /api/templates      — lista templates community
#   POST /api/templates      — upload de template
#   POST /api/highlights     — extração de highlights (client-side analysis)
#   POST /api/tts/synthesize — TTS via ElevenLabs (chave do usuário no header)
#   ALL  /api/proxy/elevenlabs/* — proxy ElevenLabs
#   ALL  /api/proxy/openai/*    — proxy OpenAI
#   ALL  /api/proxy/anthropic/* — proxy Anthropic
